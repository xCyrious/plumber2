{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "corepack pnpm --filter @workspace/rheyler-plumbing dev",
    "build": "corepack pnpm --filter @workspace/rheyler-plumbing build",
    "preview": "corepack pnpm --filter @workspace/rheyler-plumbing preview",
    "start": "corepack pnpm --filter @workspace/rheyler-plumbing preview",
    "build:all": "corepack pnpm run typecheck && corepack pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm --filter @workspace/rheyler-plumbing typecheck"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
